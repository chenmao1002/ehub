{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure Debug",
            "type": "shell",
            "command": "F:/vscode/openstm32/cmake/bin/cmake.exe",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build/Debug",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-G",
                "Ninja",
                "-DCMAKE_MAKE_PROGRAM=F:/vscode/openstm32/ninja-win/ninja.exe"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake Configure Release",
            "type": "shell",
            "command": "F:/vscode/openstm32/cmake/bin/cmake.exe",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build/Release",
                "-DCMAKE_BUILD_TYPE=Release",
                "-G",
                "Ninja",
                "-DCMAKE_MAKE_PROGRAM=F:/vscode/openstm32/ninja-win/ninja.exe"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "F:/vscode/openstm32/cmake/bin/cmake.exe",
            "args": [
                "--build",
                "${workspaceFolder}/build/Debug",
                "--parallel"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": {
                "owner": "gcc",
                "fileLocation": [
                    "absolute"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "dependsOn": "CMake Configure Debug"
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "F:/vscode/openstm32/cmake/bin/cmake.exe",
            "args": [
                "--build",
                "${workspaceFolder}/build/Release",
                "--parallel"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": {
                "owner": "gcc",
                "fileLocation": [
                    "absolute"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "dependsOn": "CMake Configure Release"
        },
        {
            "label": "Flash (OpenOCD)",
            "type": "shell",
            "command": "F:/vscode/openstm32/xpack-openocd/xpack-openocd-0.12.0-4/bin/openocd.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "-s",
                "F:/vscode/openstm32/xpack-openocd/xpack-openocd-0.12.0-4/openocd/scripts",
                "-f",
                "${workspaceFolder}/openocd.cfg",
                "-c",
                "program build/Debug/EHUB.hex verify reset exit"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Clean Debug",
            "type": "shell",
            "command": "F:/vscode/openstm32/cmake/bin/cmake.exe",
            "args": [
                "--build",
                "${workspaceFolder}/build/Debug",
                "--target",
                "clean"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build STM",
            "type": "process",
            "command": "${command:stm32-for-vscode.build}",
            "options": {
                "cwd": "${workspaceRoot}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build Clean STM",
            "type": "process",
            "command": "${command:stm32-for-vscode.cleanBuild}",
            "options": {
                "cwd": "${workspaceRoot}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Flash STM",
            "type": "process",
            "command": "${command:stm32-for-vscode.flash}",
            "options": {
                "cwd": "${workspaceRoot}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Flash WiFi DAP (OpenOCD TCP)",
            "type": "shell",
            "command": "F:/vscode/openstm32/xpack-openocd/xpack-openocd-0.12.0-4/bin/openocd.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "-s",
                "F:/vscode/openstm32/xpack-openocd/xpack-openocd-0.12.0-4/openocd/scripts",
                "-f",
                "${workspaceFolder}/openocd_wifi_dap.cfg",
                "-c",
                "program build/Debug/EHUB.hex verify reset exit"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "DAP TCP Test",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/tools/dap_tcp_test.py",
                "--host",
                "ehub.local",
                "--port",
                "6000"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Install elaphureLink to Keil",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/tools/elaphureLink/install_elaphurelink.ps1"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "ESP32 Download Mode",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/tools/esp32_download_mode.py",
                "--port",
                "COM19"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "ESP32 Build",
            "type": "shell",
            "command": "pio",
            "args": [
                "run"
            ],
            "options": {
                "cwd": "${workspaceFolder}/ESP32_wifi"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "ESP32 Upload",
            "type": "shell",
            "command": "pio",
            "args": [
                "run",
                "-t",
                "upload",
                "--upload-port",
                "COM18"
            ],
            "options": {
                "cwd": "${workspaceFolder}/ESP32_wifi"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "dependsOn": "ESP32 Download Mode"
        },
        {
            "label": "ESP32 Flash + MCU Restore",
            "dependsOn": [
                "ESP32 Upload",
                "Flash (OpenOCD)"
            ],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": []
        }
    ]
}
